# ---------------------------------------------------------------------------
# Shared database with the main system (Courtside Live)
# ---------------------------------------------------------------------------
# The website reads the SAME Turso (libSQL) database that Courtside Live writes
# to. Point these at that database and every tab — games, box scores, standings,
# leaders, teams and player profiles — shows your live games in near real-time.
#
# Use the exact same two values that are set on the Courtside Live (Render)
# service, so both apps share one database:
#   TURSO_DATABASE_URL = libsql://<your-db>-<org>.turso.io
#   TURSO_AUTH_TOKEN   = <token from the Turso dashboard>
#
# These are server-only (never exposed to the browser). If they are unset or the
# database is unreachable, the site automatically falls back to the main system's
# public HTTP feed (https://courtside-live.onrender.com/api/feed/games), so it
# keeps working either way.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Passcode statisticians enter on /statistician to publish photos.
COURTSIDE_UPLOAD_CODE=courtside
